---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPosts, getTags } from "../../utils/posts";

const posts = await getPosts();
const tags = getTags(posts);
---

<BaseLayout title="Tags" description="Browse Aqwddda Log by topic.">
  <h1 class="page-heading">Tags</h1>
  <p class="page-intro">
    Browse topics across recommendation systems, RAG and AI engineering.
  </p>

  {
    tags.length > 0 ? (
      <ul class="tag-cloud" aria-label="All tags">
        {tags.map((tag) => (
          <li>
            <a href={`/tags/${tag.slug}/`}>
              <span>{tag.name}</span>
              <sup aria-label={`${tag.count} articles`}>{tag.count}</sup>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-state">No tags yet.</p>
    )
  }
</BaseLayout>

<style>
  .tag-cloud {
    display: flex;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    gap: 0.8rem;
    list-style: none;
  }

  .tag-cloud a {
    display: flex;
    min-height: 2.65rem;
    padding: 0.55rem 0.75rem;
    align-items: flex-start;
    gap: 0.3rem;
    border: 1px solid var(--border);
    border-radius: 7px;
    background: color-mix(in srgb, var(--surface) 65%, var(--border));
    color: var(--text);
    font-size: 1rem;
    font-weight: 650;
    line-height: 1.35;
    text-decoration: none;
  }

  .tag-cloud a:hover {
    border-color: var(--muted);
    background: var(--surface);
    color: var(--accent);
  }

  .tag-cloud sup {
    color: var(--muted);
    font-size: 0.7rem;
    font-weight: 600;
    line-height: 1;
  }
</style>
