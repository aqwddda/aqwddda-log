---
import { siteConfig } from "../config";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-shell footer-inner">
    <p>© {year} {siteConfig.author}. Built for long-term technical notes.</p>
    <a href={siteConfig.githubProfileUrl} target="_blank" rel="noreferrer">GitHub</a>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.85rem;
  }

  .footer-inner {
    display: flex;
    min-height: 5rem;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-footer p {
    margin: 0;
  }

  @media (max-width: 520px) {
    .footer-inner {
      align-items: flex-start;
      flex-direction: column;
      justify-content: center;
    }
  }
</style>
